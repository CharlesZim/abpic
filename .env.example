# Server-only Supabase credentials (do not prefix with NEXT_PUBLIC_)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Public Supabase values, exposed to the browser for direct photo uploads
# (signed-URL uploads). The anon/publishable key is safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
